@startuml 主流程图
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Microsoft YaHei"
skinparam defaultFontSize 11
skinparam activity {
    BorderColor #334155
    BackgroundColor #F8FAFC
    FontSize 11
}
skinparam arrowColor #475569
skinparam arrowThickness 2

title 无尽跑酷游戏 - 总流程

start
:进入主菜单;
repeat
  if (玩家选择操作?) then (开始游戏)
    :初始化游戏数据\n(分数/角色/赛道);
    :进入子模块A\n游戏流程与角色操控;
    if (触发子模块B?) then (规避/收集)
      :赛道环境与道具系统;
    endif
    if (触发子模块C?) then (释放技能)
      :技能系统;
    endif
    if (角色死亡?) then (是)
      if (使用时间回溯?\n已解锁且未使用) then (是)
        :子模块C\n时间回溯流程;
        detach
      else (否/条件不满足)
        :进入结算界面;
      endif
    else (否)
    endif
    :显示本次得分\n最高分对比;
    if (玩家选择?) then (重新开始)
    else (返回主菜单)
    endif
  elseif (查看最高分) then
    :显示历史最高分;
  else (退出游戏)
    stop
  endif
repeat while (留在主菜单?) is (是)
stop
@enduml