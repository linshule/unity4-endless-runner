@startuml 子模块B_赛道环境与道具系统
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Microsoft YaHei"
skinparam defaultFontSize 11
skinparam activity {
    BorderColor #15803D
    BackgroundColor #F0FDF4
    FontSize 11
}
skinparam arrowColor #15803D
skinparam arrowThickness 2

title 子模块B：赛道环境与道具系统

start
:赛道持续生成\n障碍/道具;
while (游戏进行中?) is (是)
  if (前方出现威胁/道具?) then (障碍/机关/陷阱/塌陷)
    :检测威胁类型;
    if (玩家规避成功?\n滑铲/变道/跳跃) then (是)
      :成功规避\n继续前进;
    else (否)
      :角色死亡;
      detach
    endif
  elseif (金币/双倍分数) then
    :玩家拾取道具;
    if (拾取类型?) then (金币)
      :分数增加\n金币分值;
      :更新得分显示;
    else (双倍分数)
      :激活双倍分数效果;
      :提示双倍分数生效;
    endif
  else (无障碍/道具)
    :正常前进;
  endif
endwhile (否)
stop
@enduml