digraph ModuleA {
    splines=ortho;
    rankdir=TB;
    bgcolor="#FEFEFE";
    label="子模块A：游戏流程与角色操控";
    labeljust=l;
    fontname="Microsoft YaHei";
    fontsize=16;
    fontcolor="#1E293B";
    pad=0.5;
    nodesep=0.4;
    ranksep=0.5;

    node [fontname="Microsoft YaHei", fontsize=11, penwidth=1.5];
    edge [fontname="Microsoft YaHei", fontsize=10];

    /* ===== Start / End ===== */
    node [shape=box, style=rounded, fillcolor="#E8F5E9", color="#2E7D32", penwidth=2];
    start [label="开始\n(从主菜单进入)"];
    end_node [label="结束\n(回到主菜单)"];

    /* ===== Process ===== */
    node [shape=box, fillcolor="#F8FAFC", color="#334155", penwidth=1.5];
    init    [label="初始化游戏数据\n(分数/角色/赛道)"];
    loop    [label="游戏主循环"];
    doSlide [label="执行滑铲动作\n碰撞检测"];
    doLane  [label="切换跑道\n规避障碍"];
    doJump  [label="执行跳跃动作\n腾空判定"];
    update  [label="继续游戏\n更新分数"];
    death   [label="角色死亡\n播放死亡动画"];
    showScore [label="显示当前分数"];
    pauseDisplay [label="暂停计时\n显示暂停界面"];
    settlement  [label="进入结算界面"];
    resultDisp  [label="显示结算信息\n得分/最高分对比"];

    /* ===== Decision ===== */
    node [shape=diamond, fillcolor="#FFF3E0", color="#E65100", margin="0.2,0.15"];
    inputQ      [label="玩家输入\n操作?"];
    opType      [label="操作类型?"];
    hitCheck    [label="碰撞障碍\n/地形?"];
    rewindQ     [label="使用时间回溯?\n(1500分解锁\n每局1次/列车未追上)"];
    pauseQ      [label="玩家选择?"];
    finalQ      [label="玩家选择?"];

    /* ===== I/O ===== */
    node [shape=parallelogram, fillcolor="#E3F2FD", color="#1565C0"];
    dispScore   [label="显示\n结算信息"];

    /* ===== Edges ===== */
    start       -> init;
    init        -> loop;

    loop        -> inputQ;

    inputQ      -> opType        [xlabel="操控角色"];
    opType      -> doSlide       [xlabel="滑铲"];
    opType      -> doLane        [xlabel="左右变道"];
    opType      -> doJump        [xlabel="跳跃"];
    doSlide     -> hitCheck;
    doLane      -> hitCheck;
    doJump      -> hitCheck;

    hitCheck    -> update        [xlabel="否"];
    update      -> loop;
    hitCheck    -> death         [xlabel="是"];

    inputQ      -> pauseDisplay  [xlabel="暂停游戏"];
    pauseDisplay -> pauseQ;
    pauseQ      -> loop          [xlabel="恢复游戏"];
    pauseQ      -> settlement    [xlabel="返回主菜单"];

    inputQ      -> showScore     [xlabel="查看得分"];
    showScore   -> loop;

    death       -> rewindQ;
    rewindQ     -> loop          [xlabel="是\n(时间回溯)"];
    rewindQ     -> settlement    [xlabel="否\n条件不满足"];

    settlement  -> resultDisp;
    resultDisp  -> finalQ;
    finalQ      -> init          [xlabel="重新开始"];
    finalQ      -> end_node      [xlabel="返回主菜单"];
}
