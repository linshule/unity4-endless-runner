digraph ModuleC {
    splines=ortho;
    rankdir=TB;
    bgcolor="#FEFEFE";
    label="子模块C：技能系统";
    labeljust=l;
    fontname="Microsoft YaHei";
    fontsize=16;
    fontcolor="#1E293B";
    pad=0.5;
    nodesep=0.4;
    ranksep=0.5;

    node [fontname="Microsoft YaHei", fontsize=11, penwidth=1.5];
    edge [fontname="Microsoft YaHei", fontsize=10];

    /* ===== Start / End ===== */
    node [shape=box, style=rounded, fillcolor="#E8F5E9", color="#2E7D32", penwidth=2];
    start [label="开始\n(按下技能键/死亡触发)"];
    end_node [label="结束\n(回到游戏主循环)"];

    /* ===== Process ===== */
    node [shape=box, fillcolor="#F8FAFC", color="#334155", penwidth=1.5];
    dashExec    [label="前冲30m\n清障+无敌"];
    cloneExec   [label="三轨道生成分身\n持续6秒自动拾取金币"];
    rewindExec  [label="回退至碰撞前2秒\n恢复角色状态"];
    dashCooldown  [label="进入冷却计时\n(45s)"];
    cloneCooldown [label="进入冷却计时\n(25s)"];
    markUsed      [label="标记本局\n回溯已使用"];
    goSettlement  [label="进入结算界面"];

    /* ===== Decision ===== */
    node [shape=diamond, fillcolor="#FFF3E0", color="#E65100", margin="0.2,0.15"];
    skillQ      [label="触发技能\n类型?"];
    dashCoolQ   [label="冷却完成?\n(45s)"];
    cloneCoolQ  [label="冷却完成?\n(25s)"];
    rewindCondQ [label="满足触发条件?\n(1500分解锁+未使用\n+列车未追上)"];

    /* ===== I/O ===== */
    node [shape=parallelogram, fillcolor="#E3F2FD", color="#1565C0"];
    dashTip   [label="提示:\n技能冷却中"];
    cloneTip  [label="提示:\n技能冷却中"];
    rewindTip [label="提示:\n无法使用时间回溯"];

    /* ===== Edges ===== */
    start       -> skillQ;

    skillQ      -> dashCoolQ     [xlabel="虚空冲刺\n(E键)"];
    dashCoolQ   -> dashExec      [xlabel="是"];
    dashExec    -> dashCooldown;
    dashCooldown -> end_node;
    dashCoolQ   -> dashTip       [xlabel="否"];
    dashTip     -> end_node;

    skillQ      -> cloneCoolQ    [xlabel="幻影分身\n(R键)"];
    cloneCoolQ  -> cloneExec     [xlabel="是"];
    cloneExec   -> cloneCooldown;
    cloneCooldown -> end_node;
    cloneCoolQ  -> cloneTip      [xlabel="否"];
    cloneTip    -> end_node;

    skillQ      -> rewindCondQ   [xlabel="时间回溯\n(死亡触发)"];
    rewindCondQ -> rewindExec    [xlabel="是"];
    rewindExec  -> markUsed;
    markUsed    -> end_node;
    rewindCondQ -> rewindTip     [xlabel="否"];
    rewindTip   -> goSettlement;
    goSettlement -> end_node;
}
