@startuml 子模块C_技能系统
skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Microsoft YaHei"
skinparam defaultFontSize 11
skinparam activity {
    BorderColor #7C3AED
    BackgroundColor #F5F3FF
    FontSize 11
}
skinparam arrowColor #7C3AED
skinparam arrowThickness 2

title 子模块C：技能系统

start
:玩家按下技能键\n或死亡触发;
if (触发技能类型?) then (虚空冲刺)
  if (冷却完成?\n冷却45s) then (是)
    :前冲30m\n清障+无敌;
    :进入冷却计时;
  else (否)
    :提示\n技能冷却中;
  endif
elseif (幻影分身) then
  if (冷却完成?\n冷却25s) then (是)
    :三轨道生成分身\n持续6秒自动拾取金币;
    :进入冷却计时;
  else (否)
    :提示\n技能冷却中;
  endif
elseif (时间回溯) then
  if (满足触发条件?\n1500分解锁+未使用+列车未追上) then (是)
    :回退至碰撞前2秒\n恢复角色状态;
    :标记本局回溯已使用;
  else (否)
    :提示\n无法使用时间回溯;
    :进入结算界面;
    detach
  endif
endif
stop
@enduml